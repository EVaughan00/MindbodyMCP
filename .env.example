# =============================================================================
# Multi-tenant hosted deployment (Vercel) — the /api functions use these
# =============================================================================

# Admin portal password (HTTP Basic). REQUIRED to use /admin.
# Username is ignored; only the password is checked.
ADMIN_PASSWORD=change-me-to-a-strong-secret

# Durable storage for tenants + OAuth tokens (Upstash Redis / Vercel KV).
# Add the Upstash integration in the Vercel dashboard and these are set for you.
# Locally, leave blank to use an in-memory store (data is not persisted).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Public base URL of the deployment. Optional — auto-derived from request
# headers on Vercel. Set it if discovery/redirect URLs come out wrong.
# PUBLIC_BASE_URL=https://your-app.vercel.app

# =============================================================================
# Local single-tenant CLI only (stdio / SSE via `npm run dev`)
# Not used by the hosted multi-tenant /api functions.
# =============================================================================
MINDBODY_API_KEY=your_api_key_here
MINDBODY_SITE_ID=-99
MINDBODY_SOURCE_NAME=your_source_name
MINDBODY_SOURCE_PASSWORD=your_source_password

MINDBODY_API_URL=https://api.mindbodyonline.com/public/v6
CACHE_TTL_MINUTES=5

MCP_SERVER_NAME=mindbody-mcp
MCP_SERVER_VERSION=2.0.0
MCP_TRANSPORT=stdio
MCP_PORT=3000
MCP_HOST=0.0.0.0
